[6.251732, "o", "#!/usr/bin/env bash\r\n# Uses the new @aws/agentcore CLI — github.com/aws/agentcore-cli\r\nagentcore create --name Aim308Deploy --no-agent --defaults \\\r\n    --skip-install --skip-python-setup --skip-git\r\n\r\ncd Aim308Deploy\r\nagentcore add agent \\\r\n    --name aim308_research_agent \\\r\n    --type byo --language Python --framework Strands \\\r\n    --model-provider Bedrock \\\r\n    --code-location ../code/step-05-deploy \\\r\n    --entrypoint agent.py --protocol HTTP\r\n\r\necho \"AWS_REGION=us-east-1\"                              >> agentcore/.env.local\r\necho \"BEDROCK_AGENTCORE_MEMORY_ID=$BEDROCK_AGENTCORE_MEMORY_ID\" >> agentcore/.env.local\r\n\r\n(cd agentcore/cdk && npm install --loglevel=error)\r\nagentcore deploy -y\r\n"]
